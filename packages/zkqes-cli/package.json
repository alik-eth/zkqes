    "dist/src/**/*",
    "scripts/postinstall-shim.cjs",
    "README.md"
  ],
  "dependencies": {
    "commander": "^12.0.0",
    "snarkjs": "^0.7.4",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
