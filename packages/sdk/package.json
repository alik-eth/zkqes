{
  "name": "@zkqes/sdk",
  "version": "0.5.2-pre",
  "description": "zkqes SDK — verify QES, build proofs, register on-chain.",
  "type": "module",
  "license": "GPL-3.0-or-later",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./prover/snarkjs": {
      "types": "./dist/prover/snarkjs.d.ts",
      "import": "./dist/prover/snarkjs.js"
    },
    "./prover/snarkjsWorker": {
      "types": "./dist/prover/snarkjsWorker.d.ts",
      "import": "./dist/prover/snarkjsWorker.js"
    },
    "./prover/snarkjsWorkerEntry": {
      "types": "./dist/prover/snarkjsWorkerEntry.d.ts",
      "import": "./dist/prover/snarkjsWorkerEntry.js"
    },
    "./prover/verify": {
      "types": "./dist/prover/verify.d.ts",
      "import": "./dist/prover/verify.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "assets",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "drift-check": "node scripts/check-circuits-vendor-drift.mjs",
    "drift-check:update-lock": "node scripts/check-circuits-vendor-drift.mjs --update-lock"
  },
  "dependencies": {
    "@noble/hashes": "^1.4.0",
    "@noble/secp256k1": "^2.1.0",
    "asn1js": "^3.0.7",
    "canonicalize": "^3.0.0",
    "circomlibjs": "^0.1.7",
    "pkijs": "^3.4.0",
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "snarkjs": "^0.7",
    "viem": "^2.21.0"
  },
  "peerDependenciesMeta": {
    "snarkjs": {
      "optional": true
    },
    "viem": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/node-forge": "^1.3.11",
    "node-forge": "^1.3.1",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
