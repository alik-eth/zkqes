{
  "name": "@zkqes/circuits",
  "version": "0.0.0",
  "private": true,
  "description": "zkqes — Circom circuits for the V5 presentation proof (ECDSA-on-chain, Poseidon nullifiers, single-circuit ZK proof)",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "test": "mocha --reporter spec --exit --timeout 600000 -r ts-node/register 'test/**/*.test.ts'",
    "test:vitest": "vitest run",
    "test:v5": "mocha --reporter spec --exit --timeout 600000 -r ts-node/register 'test/integration/{qkb-presentation-v5,build-witness-v5,v5-e2e,v5-prove-verify}.test.ts'",
    "build": "bash ceremony/scripts/compile.sh",
    "compile:v5": "mkdir -p build/zkqes-presentation && circom circuits/ZkqesPresentationV5.circom --r1cs --wasm -l circuits -l node_modules -o build/zkqes-presentation/ && pnpm exec snarkjs r1cs info build/zkqes-presentation/ZkqesPresentationV5.r1cs",
    "ceremony:v5:stub": "bash ceremony/scripts/stub-v5.sh",
    "ceremony:v5_1:stub": "bash ceremony/scripts/stub-v5_1.sh",
    "ceremony:v5_2:stub": "bash ceremony/scripts/stub-v5_2.sh",
    "ceremony:v5_3:stub": "bash ceremony/scripts/stub-v5_3.sh",
    "ceremony:v5_5:stub": "bash ceremony/scripts/stub-v5_5.sh",
    "lint": "biome check .",
    "extract:spkis": "ts-node scripts/extract-spkis.ts",
    "parity:v5": "vitest run test/SpkiCommitParity.vitest.ts",
    "parity:v5:emit": "ts-node scripts/emit-spki-parity-fixture.ts",
    "build-witness-v5": "ts-node bin/build-witness-v5.ts",
    "prove:v5_2": "node --max-old-space-size=24576 scripts/v5_2-prove.mjs"
  },
  "bin": {
    "build-witness-v5": "bin/build-witness-v5.ts"
  },
  "devDependencies": {
    "@noble/hashes": "^2.2.0",
    "@types/chai": "^4.3.16",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.12.0",
    "@zk-email/circuits": "6.3.4",
    "asn1js": "^3.0.7",
    "chai": "^4.4.1",
    "circom_tester": "^0.0.20",
    "circomlib": "^2.0.5",
    "circomlibjs": "^0.1.7",
    "mocha": "^10.4.0",
    "pkijs": "3.4.0",
    "snarkjs": "^0.7.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
