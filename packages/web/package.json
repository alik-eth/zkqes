{
  "name": "@zkqes/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm -F @zkqes/lotl-flattener build && node scripts/generate-qtsp-index.mjs && node scripts/generate-qtsp-summary.mjs",
    "dev": "vite",
    "prebuild": "pnpm -F @zkqes/lotl-flattener build && node scripts/generate-qtsp-index.mjs && node scripts/generate-qtsp-summary.mjs",
    "build": "tsc -b && vite build",
    "pretypecheck": "pnpm -F @zkqes/lotl-flattener build && node scripts/generate-qtsp-index.mjs && node scripts/generate-qtsp-summary.mjs",
    "preview": "vite preview --port 4173 --strictPort --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:bundle-size": "RUN_BUNDLE_SIZE=1 vitest run tests/build/landing-bundle-size.test.ts",
    "compute-policy-root": "node scripts/compute-policy-root.mjs",
    "generate-qtsp-index": "node scripts/generate-qtsp-index.mjs",
    "generate-diia-evidence": "node scripts/generate-diia-evidence.mjs",
    "package": "pnpm run build && node scripts/pack.mjs",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@noble/ciphers": "^1.0.0",
    "@noble/hashes": "^1.4.0",
    "@noble/secp256k1": "^2.1.0",
    "@rainbow-me/rainbowkit": "^2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "^1.45.0",
    "@types/zxcvbn": "^4.4.5",
    "@zkqes/sdk": "workspace:*",
    "asn1js": "^3.0.7",
    "buffer": "^6.0.3",
    "canonicalize": "^3.0.0",
    "circomlibjs": "^0.1.7",
    "d3-geo": "^3.1.1",
    "hash-wasm": "^4.12.0",
    "i18next": "^23.11.5",
    "pkijs": "^3.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.2",
    "snarkjs": "^0.7",
    "tailwindcss": "^4.2.2",
    "topojson-client": "^3.1.0",
    "viem": "^2.21.0",
    "wagmi": "^2",
    "world-atlas": "^2.0.2",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/d3-geo": "^3.1.0",
    "@types/geojson": "^7946.0.16",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/topojson-client": "^3.1.5",
    "@types/topojson-specification": "^1.0.5",
    "@vitejs/plugin-react": "^4.3.1",
    "@zkqes/cli": "file:./test/fixtures/zkqes-cli-0.5.2-pre.tgz",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "jsdom": "^24.1.0",
    "node-forge": "^1.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.3.0",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vitest": "^2.0.0"
  }
